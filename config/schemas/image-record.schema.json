{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://con.github.io/STAMPED-dl_morphometrics_biases/schemas/image-record.schema.json",
  "title": "Scientific image registry record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "image_id",
    "state",
    "source_kind",
    "architecture",
    "interface",
    "licenses",
    "retrieval_locations",
    "qualification",
    "hardening"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "image_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
    "state": {
      "enum": ["discovered", "candidate", "qualified", "accepted-registered", "superseded", "rejected"]
    },
    "source_kind": { "enum": ["external-datalad", "project-built"] },
    "architecture": { "enum": ["x86_64", "aarch64"] },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "version"],
      "properties": {
        "kind": { "enum": ["bids-app", "tool"] },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "licenses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "identifier", "redistribution"],
        "properties": {
          "component": { "type": "string", "minLength": 1 },
          "identifier": { "type": "string", "minLength": 1 },
          "redistribution": { "enum": ["permitted", "prohibited", "restricted", "unresolved"] }
        }
      }
    },
    "retrieval_locations": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "uniqueItems": true
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interface", "containment", "fixture", "target_architecture", "persistent_retrieval"],
      "properties": {
        "interface": { "$ref": "#/$defs/gate" },
        "containment": { "$ref": "#/$defs/gate" },
        "fixture": { "$ref": "#/$defs/gate" },
        "target_architecture": { "$ref": "#/$defs/gate" },
        "persistent_retrieval": { "$ref": "#/$defs/gate" }
      }
    },
    "hardening": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sbom", "signature", "attestation"],
      "properties": {
        "sbom": { "$ref": "#/$defs/decision" },
        "signature": { "$ref": "#/$defs/decision" },
        "attestation": { "$ref": "#/$defs/decision" }
      }
    },
    "source_dataset_id": { "$ref": "#/$defs/uuid" },
    "source_dataset_commit": { "$ref": "#/$defs/git_commit" },
    "source_annex_key": { "type": "string", "minLength": 1 },
    "source_reference": { "type": "string", "format": "uri" },
    "definition_path": { "$ref": "#/$defs/relative_path" },
    "definition_sha256": { "$ref": "#/$defs/sha256" },
    "pixi_manifest_sha256": { "$ref": "#/$defs/sha256" },
    "pixi_lock_sha256": { "$ref": "#/$defs/sha256" },
    "builder_version": { "type": "string", "minLength": 1 },
    "build_command": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "accepted_dataset_id": { "$ref": "#/$defs/uuid" },
    "accepted_dataset_commit": { "$ref": "#/$defs/git_commit" },
    "accepted_image_path": { "$ref": "#/$defs/relative_path" },
    "sif_annex_key": { "type": "string", "pattern": "^SHA256E-s[0-9]+--[0-9a-f]{64}(?:\\.[A-Za-z0-9_-]+)*\\.sif$" },
    "sif_sha256": { "$ref": "#/$defs/sha256" }
  },
  "allOf": [
    {
      "if": { "properties": { "source_kind": { "const": "external-datalad" } } },
      "then": {
        "required": ["source_dataset_id", "source_dataset_commit", "source_annex_key", "source_reference"]
      },
      "else": {
        "required": [
          "definition_path",
          "definition_sha256",
          "pixi_manifest_sha256",
          "pixi_lock_sha256",
          "builder_version",
          "build_command"
        ]
      }
    },
    {
      "if": { "properties": { "state": { "const": "accepted-registered" } } },
      "then": {
        "required": ["accepted_dataset_id", "accepted_dataset_commit", "accepted_image_path", "sif_annex_key", "sif_sha256"]
      }
    }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^(?:/|.*(?:^|/)\\.\\.(?:/|$))" }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence"],
      "properties": {
        "status": { "enum": ["pass", "fail", "pending", "not-applicable"] },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "rationale"],
      "properties": {
        "decision": { "enum": ["adopt", "defer", "decline"] },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
