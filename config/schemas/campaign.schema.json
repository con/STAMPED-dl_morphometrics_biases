{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://con.github.io/STAMPED-dl_morphometrics_biases/schemas/campaign.schema.json",
  "title": "Resolved STAMPED campaign",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "created_at",
    "access_class",
    "dataset",
    "pipeline",
    "cluster",
    "attempt",
    "resources",
    "outputs",
    "retry_policy"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "campaign_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
    "created_at": { "type": "string", "format": "date-time" },
    "access_class": {
      "enum": ["public", "controlled", "private", "disclosure-reviewed-public"]
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "study_id",
        "study_dataset_id",
        "study_commit",
        "raw_dataset_id",
        "raw_commit",
        "requested_inclusion"
      ],
      "properties": {
        "study_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
        "study_dataset_id": { "$ref": "#/$defs/uuid" },
        "study_commit": { "$ref": "#/$defs/git_commit" },
        "raw_dataset_id": { "$ref": "#/$defs/uuid" },
        "raw_commit": { "$ref": "#/$defs/git_commit" },
        "requested_inclusion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "$ref": "#/$defs/relative_path" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pipeline_id",
        "pipeline_version",
        "config_path",
        "config_sha256",
        "container_id",
        "accepted_container_dataset_id",
        "accepted_container_commit",
        "sif_annex_key",
        "sif_sha256",
        "input_condition"
      ],
      "properties": {
        "pipeline_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
        "pipeline_version": { "type": "string", "minLength": 1 },
        "config_path": { "$ref": "#/$defs/relative_path" },
        "config_sha256": { "$ref": "#/$defs/sha256" },
        "container_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
        "accepted_container_dataset_id": { "$ref": "#/$defs/uuid" },
        "accepted_container_commit": { "$ref": "#/$defs/git_commit" },
        "sif_annex_key": { "type": "string", "pattern": "^SHA256E-s[0-9]+--[0-9a-f]{64}\\.sif$" },
        "sif_sha256": { "$ref": "#/$defs/sha256" },
        "input_condition": { "type": "string", "minLength": 1 }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "profile_path", "profile_sha256", "scheduler", "host_interfaces"],
      "properties": {
        "profile_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
        "profile_path": { "$ref": "#/$defs/relative_path" },
        "profile_sha256": { "$ref": "#/$defs/sha256" },
        "scheduler": { "const": "slurm" },
        "host_interfaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_id",
        "derivative_path",
        "derivative_dataset_id",
        "operations_dataset_id"
      ],
      "properties": {
        "attempt_id": { "type": "string", "pattern": "^attempt-[0-9]{3}$" },
        "derivative_path": {
          "type": "string",
          "pattern": "^studies/[a-z0-9-]+/derivatives/[a-z0-9-]+-attempt-[0-9]{3}/$"
        },
        "derivative_dataset_id": { "$ref": "#/$defs/uuid" },
        "operations_dataset_id": { "$ref": "#/$defs/uuid" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpus_per_task", "memory_mb", "walltime_minutes", "scratch_mb"],
      "properties": {
        "cpus_per_task": { "type": "integer", "minimum": 1 },
        "memory_mb": { "type": "integer", "minimum": 1 },
        "walltime_minutes": { "type": "integer", "minimum": 1 },
        "scratch_mb": { "type": "integer", "minimum": 1 },
        "gpus": { "type": "integer", "minimum": 0 }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "access_class"],
        "properties": {
          "path": { "$ref": "#/$defs/relative_path" },
          "kind": { "enum": ["derivative", "log", "operations-evidence", "aggregate"] },
          "access_class": {
            "enum": ["public", "controlled", "private", "disclosure-reviewed-public"]
          }
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_retries", "retryable_reasons", "scientific_change_requires_new_campaign"],
      "properties": {
        "max_retries": { "type": "integer", "minimum": 0 },
        "retryable_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "scientific_change_requires_new_campaign": { "const": true }
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^(?:/|.*(?:^|/)\\.\\.(?:/|$))" }
    }
  }
}
