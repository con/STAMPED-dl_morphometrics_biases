Bootstrap: docker
From: alpine@sha256:d9e853e87e55526f6b2917df91a2115c36dd7c696a35be12163d44e6e2a4b6bc

%labels
    org.opencontainers.image.title toy-bids-app
    org.opencontainers.image.description Redistributable BIDS App interface fixture for registry testing only
    org.opencontainers.image.version 0.1.0

%post
    mkdir -p /etc
    : > /etc/localtime
    cat > /usr/local/bin/toy-bids-app <<'EOF'
#!/bin/sh
set -eu

case "${1:-}" in
    --help|-h)
        printf '%s\n' 'usage: toy-bids-app bids_dir output_dir participant [--participant_label LABEL]'
        exit 0
        ;;
    --version)
        printf '%s\n' 'toy-bids-app 0.1.0'
        exit 0
        ;;
esac

if [ "$#" -lt 3 ] || [ "$3" != "participant" ]; then
    printf '%s\n' 'toy-bids-app requires bids_dir, output_dir, and analysis_level=participant' >&2
    exit 64
fi

if [ ! -f "$1/dataset_description.json" ]; then
    printf '%s\n' 'toy-bids-app requires a BIDS dataset_description.json input' >&2
    exit 65
fi

mkdir -p "$2"
cat > "$2/dataset_description.json" <<'JSON'
{"Name":"Toy BIDS App derivative","BIDSVersion":"1.11.1","DatasetType":"derivative","GeneratedBy":[{"Name":"toy-bids-app","Version":"0.1.0"}]}
JSON
printf '%s\n' 'toy BIDS App completed' > "$2/toy-bids-app.txt"
EOF
    chmod 0755 /usr/local/bin/toy-bids-app

%runscript
exec /usr/local/bin/toy-bids-app "$@"
